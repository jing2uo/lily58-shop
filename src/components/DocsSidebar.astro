---
const path = Astro.url.pathname;

const tree = [
  { label: "Overview", href: "/docs/" },
  {
    label: "Guides",
    children: [
      { label: "Vial Guide", href: "/docs/guide/vial/" },
      { label: "Battery Replacement", href: "/docs/guide/battery/" },
    ],
  },
  { label: "FAQ", href: "/docs/faq/" },
  {
    label: "Policies",
    children: [
      { label: "Privacy", href: "/docs/policy/privacy/" },
      { label: "Terms of Service", href: "/docs/policy/terms-of-service/" },
      { label: "Shipping & Returns", href: "/docs/policy/shipping-return/" },
    ],
  },
];

const linkClass = (href: string) =>
  [
    "block rounded-md px-3 py-1.5 transition",
    path === href
      ? "bg-canvas font-medium text-ink"
      : "text-muted hover:bg-canvas hover:text-ink",
  ].join(" ");
---

<nav class="text-sm">
  <ul class="flex flex-col gap-1">
    {
      tree.map((item) =>
        "children" in item && item.children ? (
          <li class="mt-3 first:mt-0">
            <p class="px-3 pb-1 text-xs font-semibold uppercase tracking-wider text-subtle">
              {item.label}
            </p>
            <ul class="flex flex-col gap-1">
              {item.children.map((c) => (
                <li>
                  <a href={c.href} class={linkClass(c.href)}>
                    {c.label}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ) : (
          <li>
            <a href={item.href} class={linkClass(item.href!)}>
              {item.label}
            </a>
          </li>
        ),
      )
    }
  </ul>
</nav>
