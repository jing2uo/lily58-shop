---
import { SITE, FOOTER } from "../lib/site";
const year = 2025;
---

<footer class="border-t border-line">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-5">
      <div class="md:col-span-1">
        <a
          href="/"
          class="flex items-center gap-2 text-base font-bold tracking-tight text-ink"
        >
          <img
            src="/favicon.png"
            alt=""
            width="28"
            height="28"
            class="h-7 w-7 rounded-md border border-line"
          />
          {SITE.title}
        </a>
        <p class="mt-3 max-w-xs text-sm text-muted">{SITE.tagline}.</p>
        <a
          href={`mailto:${SITE.email}`}
          class="mt-3 inline-block text-sm font-medium text-accent hover:underline"
          >{SITE.email}</a
        >
      </div>

      {
        FOOTER.map((group) => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-subtle">
              {group.title}
            </h3>
            <ul class="mt-3 flex flex-col gap-2 text-sm">
              {group.links.map((l) => (
                <li>
                  <a
                    class="text-muted transition hover:text-ink"
                    href={l.href}
                    {...("external" in l && l.external
                      ? { target: "_blank", rel: "noopener noreferrer" }
                      : {})}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-10 flex flex-col items-center justify-between gap-2 border-t border-line pt-6 text-xs text-subtle sm:flex-row"
    >
      <p>&copy; {year} guojing.io · A personal hobby project, not a company.</p>
      <p>Built with Astro · Free worldwide shipping</p>
    </div>
  </div>
</footer>
